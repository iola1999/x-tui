{
  "name": "x-tui",
  "version": "0.1.0",
  "description": "Terminal X/Twitter reader — alt-screen, mouse, inline image preview, vim-like keys.",
  "type": "module",
  "license": "MIT",
  "author": "iola1999 <iola1999@foxmail.com>",
  "homepage": "https://github.com/iola1999/x-tui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iola1999/x-tui.git"
  },
  "bugs": {
    "url": "https://github.com/iola1999/x-tui/issues"
  },
  "keywords": [
    "twitter",
    "x",
    "tui",
    "terminal",
    "cli",
    "react",
    "ink",
    "bun",
    "vim"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "x-tui": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "README.md",
    "LICENSE",
    "docs/ROADMAP.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "workspaces": ["packages/@ant/*"],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "bun run build.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src/ packages/@ant/ink/src/",
    "lint:fix": "biome lint --fix src/",
    "format": "biome format --write src/",
    "test": "bun test",
    "prepublishOnly": "bun run typecheck && bun test && bun run build"
  },
  "dependencies": {
    "sharp": "^0.34.5",
    "undici": "^7.25.0"
  },
  "devDependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "@anthropic/ink": "workspace:*",
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-reconciler": "^0.33.0",
    "@types/semver": "^7.7.1",
    "@types/stack-utils": "^2.0.3",
    "auto-bind": "^5.0.1",
    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "cli-boxes": "^4.0.1",
    "code-excerpt": "^4.0.0",
    "emoji-regex": "^10.6.0",
    "figures": "^6.1.0",
    "get-east-asian-width": "^1.5.0",
    "indent-string": "^5.0.0",
    "lodash-es": "^4.18.1",
    "react": "^19.2.5",
    "react-reconciler": "^0.33.0",
    "semver": "^7.7.4",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^4.4.0",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "usehooks-ts": "^3.1.1",
    "wrap-ansi": "^10.0.0"
  }
}
